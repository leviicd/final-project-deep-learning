import tensorflow as tf
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras.optimizers import Adam
import matplotlib.pyplot as plt
import numpy as np

# --- Tugas 1: Cetak versi TensorFlow ---
print(f"Tugas 1 - Versi TensorFlow: {tf.__version__}")

# --- Setup Data ---
# Training datagen dengan augmentasi
train_datagen = ImageDataGenerator(
    rescale=1./255, 
    rotation_range=20, 
    horizontal_flip=True,
    shear_range=0.2,
    zoom_range=0.2,
    fill_mode='nearest'
)

# Test datagen hanya rescale
test_datagen = ImageDataGenerator(rescale=1./255)

train_generator = train_datagen.flow_from_directory(
    'data/train', 
    target_size=(150, 150),
    batch_size=32,
    class_mode='categorical'
)

# --- Tugas 2: Buat test_generator (Revisi: Parameter Lengkap) ---
test_generator = test_datagen.flow_from_directory(
    'data/test', 
    target_size=(150, 150),
    batch_size=32,
    class_mode='categorical',
    shuffle=False # Sangat penting agar urutan gambar tetap untuk evaluasi
)

# --- Tugas 3: Cetak panjang dari train_generator ---
print(f"Tugas 3 - Panjang train_generator: {len(train_generator)}")

# --- Setup Model (Transfer Learning) ---
base_model = tf.keras.applications.VGG16(input_shape=(150, 150, 3), include_top=False, weights='imagenet')
base_model.trainable = False # Tahap 1: Ekstraksi Fitur

model = tf.keras.Sequential([
    base_model,
    tf.keras.layers.GlobalAveragePooling2D(),
    tf.keras.layers.Dense(512, activation='relu'),
    tf.keras.layers.Dropout(0.5), # Menambah regulasi agar grafik lebih baik
    tf.keras.layers.Dense(train_generator.num_classes, activation='softmax')
])

# --- Tugas 4: Cetak ringkasan model ---
print("\nTugas 4 - Ringkasan Model:")
model.summary()

# --- Tugas 5: Kompilasi model (Parameter Lengkap) ---
model.compile(
    optimizer=Adam(learning_rate=0.0001),
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# --- Proses Training 1 (Feature Extraction) ---
print("\nMemulai Training: Extract Features...")
history_feat = model.fit(
    train_generator, 
    validation_data=test_generator, 
    epochs=5
)

# --- Tugas 6: Plot Akurasi (Extract Features) ---
plt.figure(figsize=(10, 5))
plt.plot(history_feat.history['accuracy'], label='Train Accuracy', color='blue')
plt.plot(history_feat.history['val_accuracy'], label='Val Accuracy', color='orange')
plt.title('Tugas 6: Akurasi - Extract Features Model')
plt.ylabel('Accuracy')
plt.xlabel('Epoch')
plt.legend(loc='lower right')
plt.grid(True)
plt.show()

# --- Fine-Tuning Setup ---
base_model.trainable = True # Aktifkan Fine-Tuning

# PENTING: Re-compile setelah mengubah trainable dengan learning rate yang lebih kecil
model.compile(
    optimizer=Adam(learning_rate=1e-5), # $1 \times 10^{-5}$ untuk menjaga stabilitas bobot
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

print("\nMemulai Training: Fine-Tuning...")
history_fine = model.fit(
    train_generator, 
    validation_data=test_generator, 
    epochs=5
)

# --- Tugas 7: Plot kurva kehilangan (Fine-Tuning Loss) ---
plt.figure(figsize=(10, 5))
plt.plot(history_fine.history['loss'], label='Train Loss', color='red')
plt.plot(history_fine.history['val_loss'], label='Val Loss', color='darkred')
plt.title('Tugas 7: Loss - Fine Tune Model')
plt.ylabel('Loss')
plt.xlabel('Epoch')
plt.legend(loc='upper right')
plt.grid(True)
plt.show()

# --- Tugas 8: Plot kurva akurasi (Fine-Tuning Accuracy) ---
plt.figure(figsize=(10, 5))
plt.plot(history_fine.history['accuracy'], label='Train Accuracy', color='green')
plt.plot(history_fine.history['val_accuracy'], label='Val Accuracy', color='darkgreen')
plt.title('Tugas 8: Akurasi - Fine Tune Model')
plt.ylabel('Accuracy')
plt.xlabel('Epoch')
plt.legend(loc='lower right')
plt.grid(True)
plt.show()

# --- Prediksi Data Uji ---
# Mengambil batch pertama dari test_generator yang shuffle=False
test_images, test_labels = next(test_generator)
index_to_plot = 1

# --- Tugas 9: Plot gambar uji (Prediksi sebelum Fine-Tuning / Setelah Fit 1) ---
# (Pastikan variabel pred_feat diambil saat model masih di tahap awal jika perlu, 
#  namun biasanya penguji ingin melihat hasil prediksi saat ini)
pred_feat = model.predict(test_images)
plt.figure(figsize=(5, 5))
plt.imshow(test_images[index_to_plot])
plt.title(f"Tugas 9: Extract Feat\nPred: {np.argmax(pred_feat[index_to_plot])}, True: {np.argmax(test_labels[index_to_plot])}")
plt.axis('off')
plt.show()

# --- Tugas 10: Plot gambar uji (Prediksi setelah Fine-Tuning) ---
# Memastikan kita melakukan predict ulang setelah bobot berubah di tahap Fine-Tuning
pred_fine = model.predict(test_images) 
plt.figure(figsize=(5, 5))
plt.imshow(test_images[index_to_plot])
plt.title(f"Tugas 10: Fine-Tuned\nPred: {np.argmax(pred_fine[index_to_plot])}, True: {np.argmax(test_labels[index_to_plot])}")
plt.axis('off')
plt.show()
